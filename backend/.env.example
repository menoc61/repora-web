# Backend environment variables
# Copy to .env and adjust as needed.
# Defaults work with `docker compose up` (no changes required).

DATABASE_URL=postgres://repora:repora@localhost:5434/repora
JWT_SECRET=change-this-to-a-random-secret
ENCRYPTION_KEY=change-this-to-a-32-char-hex-key
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=nemotron-3-super:cloud
CORS_ORIGIN=http://localhost:5173
PORT=8000
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=repora-exports
S3_REGION=us-east-1
