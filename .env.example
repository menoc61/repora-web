# ─── Repora Environment Variables ──────────────────────────
# Copy this file to .env and adjust as needed.
# No changes required for quick start with Docker.

# ── Ollama (required — install Ollama before running) ──
OLLAMA_HOST=host.docker.internal
OLLAMA_MODEL=nemotron-3-super:cloud

# ── Backend secrets (change in production) ──
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-to-a-32-char-hex-key

# ── Frontend (Vite) ──
VITE_API_BASE=/api
